# ============ Postgres ============
POSTGRES_USER=vcl
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vcl
# Used by both web and worker containers
DATABASE_URL=postgresql://vcl:change-me@postgres:5432/vcl

# ============ Redis / BullMQ ============
REDIS_URL=redis://redis:6379

# ============ Ollama ============
# Local dev (docker compose): point to host-running Ollama
OLLAMA_URL=http://host.docker.internal:11434
# On Coolify, override to: http://ollama-api-xs0cc04ksc400c8g804cswow:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIM=768

# ============ Anthropic ============
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_OPUS_MODEL=claude-opus-4-7

# ============ Microsoft Graph (MSAL personal account) ============
MS_CLIENT_ID=
MS_TENANT_ID=consumers
MS_REDIRECT_URI=http://localhost:3000/api/auth/ms/callback
# Scopes: offline_access Files.Read.All User.Read

# ============ Tavily (web enrichment) ============
TAVILY_API_KEY=

# ============ NextAuth ============
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string
# Single-user credentials login
APP_USER_EMAIL=you@example.com
# bcrypt hash of your password (generate with: node -e "import('bcryptjs').then(b=>console.log(b.default.hashSync('yourpw',10)))")
APP_USER_PASSWORD_HASH=

# ============ App ============
NODE_ENV=development
LOG_LEVEL=info
